APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://127.0.0.1:8000
SESSION_SECRET_KEY=
DUCKDNS_DOMAIN=sistema-pericial
DUCKDNS_TOKEN=

# Rutas base de datos y almacenamiento
DB_PATH=data/pericial.db
UPLOAD_DIR=uploads
INFORMES_DIR=informes
FOTOS_DIR=fotos
LOGS_DIR=logs
EXPORTS_DIR=exports
# BACKUPS_DIR puede apuntar a iCloud u otra carpeta local.
# Ejemplo macOS/iCloud con espacios:
# BACKUPS_DIR="/Users/carlosblanco/Library/Mobile Documents/com~apple~CloudDocs/Casa/Trabajo Arquitecto Técnico/Sistema Pericial/Backup"
BACKUPS_DIR=backups

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Servidor
HOST=0.0.0.0
PORT=8000

# Cloudflared
CLOUDFLARED_BIN=/opt/homebrew/bin/cloudflared
